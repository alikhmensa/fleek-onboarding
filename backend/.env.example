# Google AI Studio key — used for gemini-2.5-flash-lite (profile + rationales)
# and gemini-embedding-001 (vector search). https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Pinecone serverless (free tier). Optional — without it the backend falls back
# to a local numpy vector search over data/embeddings.json.
PINECONE_API_KEY=
PINECONE_INDEX=fleek-inventory

# Shopify OAuth (app "VEND" — client_id lives in seller-integration/shopify.app.toml
# on the Shiv branch; get the secret from the Shopify Partners dashboard).
# Optional — use shopify_shop=mock in /onboard to demo without a real store.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:8000/callback/shopify
SHOPIFY_SCOPES=read_orders,read_products,read_inventory

# Where /callback/shopify redirects the browser after a successful connect
# (leave empty to return JSON instead)
FRONTEND_URL=
